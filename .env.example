# ============================
# LLM 설정
# ============================

# LLM 제공자: anthropic, openai 또는 codex
# Codex는 로컬 CLI 로그인 인증을 사용하므로 LLM API Key가 필요하지 않습니다.
LLM_PROVIDER=codex

# Anthropic Claude API 키
ANTHROPIC_API_KEY=sk-ant-

# OpenAI API 키 (LLM_PROVIDER=openai 시 사용)
# OPENAI_API_KEY=sk-

# 사용할 모델 이름 (비워두면 각 제공자 기본값 사용)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# Codex CLI 설정 (LLM_PROVIDER=codex 시 사용)
CODEX_COMMAND=codex
# CODEX_MODEL=
# 회의 추출에는 긴 추론이 필요하지 않으므로 지원 모델의 낮은 effort를 사용합니다.
CODEX_REASONING_EFFORT=low
CODEX_TIMEOUT_SECONDS=600
CODEX_ACCOUNT_USAGE_ENABLED=true
CODEX_ACCOUNT_CACHE_SECONDS=30
CODEX_ACCOUNT_TIMEOUT_SECONDS=10

# 로컬 모니터링 예산입니다. 실제 ChatGPT 요금제 잔여량과는 다릅니다.
CODEX_TOKEN_BUDGET=1000000
TOKEN_USAGE_PATH=data/usage/codex.json

# ============================
# Whisper STT 설정
# ============================

# 모델 크기: tiny, base, small, medium, large
# 크기가 클수록 정확도 높고 속도 느림 (로컬 실행)
WHISPER_MODEL=base

# ============================
# 출력 채널 활성화 여부
# ============================

OUTPUT_MARKDOWN=true
OUTPUT_SLACK=false
OUTPUT_NOTION=false
OUTPUT_KAKAO=false

# ============================
# Slack 설정 (OUTPUT_SLACK=true 시 필요)
# ============================

SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL=#study-group

# ============================
# Notion 설정 (OUTPUT_NOTION=true 시 필요)
# ============================

NOTION_API_KEY=secret_
NOTION_DATABASE_ID=

# ============================
# KakaoTalk 설정 (OUTPUT_KAKAO=true 시 필요)
# ============================

KAKAO_WEBHOOK_URL=https://

# ============================
# 데이터 저장 경로
# ============================

DATA_DIR=data/sessions

# Agent 루프 최대 반복 횟수
MAX_AGENT_ITERATIONS=10
