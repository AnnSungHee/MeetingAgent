# ============================
# LLM 설정
# ============================

# LLM 제공자: anthropic (기본) 또는 openai
LLM_PROVIDER=anthropic

# Anthropic Claude API 키
ANTHROPIC_API_KEY=sk-ant-

# OpenAI API 키 (LLM_PROVIDER=openai 시 사용)
# OPENAI_API_KEY=sk-

# 사용할 모델 이름 (비워두면 각 제공자 기본값 사용)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# ============================
# Whisper STT 설정
# ============================

# 모델 크기: tiny, base, small, medium, large
# 크기가 클수록 정확도 높고 속도 느림 (로컬 실행)
WHISPER_MODEL=base

# ============================
# 출력 채널 활성화 여부
# ============================

OUTPUT_MARKDOWN=true
OUTPUT_SLACK=false
OUTPUT_NOTION=false
OUTPUT_KAKAO=false

# ============================
# Slack 설정 (OUTPUT_SLACK=true 시 필요)
# ============================

SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL=#study-group

# ============================
# Notion 설정 (OUTPUT_NOTION=true 시 필요)
# ============================

NOTION_API_KEY=secret_
NOTION_DATABASE_ID=

# ============================
# KakaoTalk 설정 (OUTPUT_KAKAO=true 시 필요)
# ============================

KAKAO_WEBHOOK_URL=https://

# ============================
# 데이터 저장 경로
# ============================

DATA_DIR=data/sessions

# Agent 루프 최대 반복 횟수
MAX_AGENT_ITERATIONS=10
